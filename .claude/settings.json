{
  "permissions": {
    "deny": [
      "Read(file_path: **/.env)",
      "Read(file_path: **/.env.*)",
      "Read(file_path: **/secrets/**)",
      "Read(file_path: **/config/credentials.json)",
      "Bash(command: rm -rf *)",
      "Bash(command: *git push --force*)",
      "Bash(command: *git push * --force*)",
      "Bash(command: sudo *)",
      "Bash(command: *DROP TABLE*)",
      "Bash(command: *DROP DATABASE*)",
      "Bash(command: *alembic downgrade*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "echo \"ctx:${CLAUDE_CONTEXT_WINDOW_USED_PERCENTAGE}% | ${CLAUDE_WORKTREE_BRANCH:-$(git branch --show-current)} | ${CLAUDE_SESSION_NAME:-unnamed}\""
  }
}
