{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash",
      "Agent",
      "NotebookEdit"
    ],
    "deny": [
      "Read(file_path: **/.env)",
      "Read(file_path: **/.env.*)",
      "Read(file_path: **/secrets/**)",
      "Read(file_path: **/config/credentials.json)",
      "Bash(command: rm -rf *)",
      "Bash(command: *git push --force*)",
      "Bash(command: *git push * --force*)",
      "Bash(command: *git push*--force*)",
      "Bash(command: *git push origin main*)",
      "Bash(command: *git push -u origin main*)",
      "Bash(command: sudo *)",
      "Bash(command: *DROP TABLE*)",
      "Bash(command: *DROP DATABASE*)",
      "Bash(command: *alembic downgrade*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/planner-guard.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/design-guard.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/design-status-guard.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/docs-guard.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/slack-notify.sh", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/slack-notify.sh", "timeout": 10 }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/slack-notify.sh", "timeout": 10 }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "oh-my-claudecode@omc": true
  }
}
