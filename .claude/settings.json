{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash",
      "Agent",
      "NotebookEdit"
    ],
    "deny": [
      "Read(file_path: **/.env)",
      "Read(file_path: **/.env.*)",
      "Read(file_path: **/secrets/**)",
      "Read(file_path: **/config/credentials.json)",
      "Bash(command: rm -rf *)",
      "Bash(command: *git push --force*)",
      "Bash(command: *git push * --force*)",
      "Bash(command: *git push*--force*)",
      "Bash(command: *git push origin main*)",
      "Bash(command: *git push -u origin main*)",
      "Bash(command: sudo *)",
      "Bash(command: *DROP TABLE*)",
      "Bash(command: *DROP DATABASE*)",
      "Bash(command: *alembic downgrade*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/secret-scanner.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/docs-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/bash-guard.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/push-gate.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-gate.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "echo \"ctx:${CLAUDE_CONTEXT_WINDOW_USED_PERCENTAGE}% | ${CLAUDE_WORKTREE_BRANCH:-$(git branch --show-current)} | ${CLAUDE_SESSION_NAME:-unnamed}\""
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "oh-my-claudecode@omc": true
  }
}
