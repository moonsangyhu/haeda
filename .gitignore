# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/
.pytest_cache/

# Flutter
.dart_tool/
.packages
build/
*.g.dart
*.freezed.dart

# IDE
.idea/
.vscode/
*.iml
.DS_Store

# Environment
.env
!.env.example

# Local dev runtime
.local-dev/

# Slice automation runtime (all run artifacts are ephemeral)
automation/runs/
.venv-automation/

# Deployer serialization lock (worktree parallel strategy)
.deployer.lock

# Planner worktree sentinel (worktree-local, per-worktree arming)
.planner-worktree

# Design worktree sentinel
.design-worktree

# Verification uploads (local dev runtime — never commit user-uploaded media)
server/uploads/*
!server/uploads/.gitkeep
